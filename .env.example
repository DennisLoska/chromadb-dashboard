# ChromaDB connection
CHROMA_URL=http://localhost:8000

# Embedding API (OpenAI-compatible, e.g. LM Studio, vLLM, OpenAI)
# Used to generate embeddings for text search queries.
# Falls back to built-in default embedding function if unset.
EMBEDDING_API_URL=http://127.0.0.1:1234/v1/embeddings
EMBEDDING_MODEL=text-embedding-qwen3-embedding-8b
